# MongoDB connection string
# Get this from MongoDB Atlas → Database → Connect → Drivers → Node.js
# Replace <username> and <password> with your DB user credentials.
# The database name "/countdown_timer" must appear before the query string.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/countdown_timer?retryWrites=true&w=majority&appName=Cluster0